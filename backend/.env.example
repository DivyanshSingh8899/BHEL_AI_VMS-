# Application
APP_NAME=BHEL Smart AI Visitor Management System
DEBUG=false

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=bhel_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=bhel_vms
POSTGRES_PORT=5432

# JWT Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change_this_to_a_random_64_char_string
JWT_SECRET_KEY=change_this_to_another_random_64_char_string
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Face Recognition
FACE_RECOGNITION_THRESHOLD=0.60
FACE_EMBEDDING_MODEL=Facenet512
MIN_FACE_CONFIDENCE=0.85
LIVENESS_THRESHOLD=0.70

# Email (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_NAME=BHEL VMS
EMAILS_FROM_EMAIL=noreply@bhel-vms.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Storage
UPLOAD_DIR=uploads

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://bhel-vms.bhel.com"]
